# .env.test — environment variables for running tests locally with Firebase emulators.
# Copy to .env.test.local and set real values if needed. No real secrets are required.
#
# Start emulators first:
#   firebase emulators:start --only auth,firestore
#
# Then run tests:
#   FIREBASE_AUTH_EMULATOR_HOST=localhost:9099 \
#   FIRESTORE_EMULATOR_HOST=localhost:8080 \
#   yarn workspace api test

# Firebase emulator hosts (matches firebase.json ports)
FIREBASE_AUTH_EMULATOR_HOST=localhost:9099
FIRESTORE_EMULATOR_HOST=localhost:8080

# Project ID for the emulator (any value works — no real Firebase project needed)
FIREBASE_PROJECT_ID=burnbuddy-test

# API service port (used by the dev server, not required for tests)
PORT=3001

# Log level
LOG_LEVEL=silent
