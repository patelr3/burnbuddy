rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures — each user can only manage their own folder
    match /profile-pictures/{uid}/{fileName} {
      // Anyone authenticated can read profile pictures (they're public avatars)
      allow read: if request.auth != null;

      // Only the owning user can write to their own folder
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/(jpeg|png|webp)');
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
